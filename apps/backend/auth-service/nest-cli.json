{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "assets": [
      {
        "include": "config/**",
        "exclude": "config/index.ts",
        "watchAssets": true
      },
      {
        "include": "prisma/mongodb/client/**"
      }
    ]
  },
  "generateOptions": {
    "spec": false
  }
}
