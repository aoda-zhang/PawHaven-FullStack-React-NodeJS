{
  "$schema": "http://json.schemastore.org/package",
  "private": true,
  "name": "@pawhaven/auth-service",
  "main": "build/main.js",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "pnpm run prisma:generate-mongodb",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "build": "nest build",
    "turbo:build": "turbo run build --filter=@pawhaven/auth-service --env-mode=loose",
    "install:auth-service": "pnpm --filter=@pawhaven/auth-service... install",
    "typecheck": "tsc --noEmit",
    "prisma:generate-mongodb": "prisma generate --schema=./src/prisma/mongodb/schema.prisma",
    "prisma:db-push": "prisma db push --schema=./src/prisma/mongodb/schema.prisma"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/microservices": "^11.1.6",
    "@nestjs/mongoose": "^11.0.3",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.4.0",
    "@pawhaven/backend-core": "workspace:*",
    "@pawhaven/eslint-config": "workspace:*",
    "@pawhaven/shared": "workspace:*",
    "@pawhaven/tsconfig": "workspace:*",
    "@prisma/client": "^6.19.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.3",
    "@types/passport-jwt": "^4.0.1",
    "add": "^2.0.6",
    "axios": "^1.12.2",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cross-env": "^10.1.0",
    "crypto-js": "^4.2.0",
    "csurf": "^1.11.0",
    "dayjs": "^1.11.18",
    "dotenv": "^17.2.3",
    "helmet": "^8.1.0",
    "mongoose": "^8.19.1",
    "nestjs-zod": "^5.1.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.7.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.3",
    "prisma": "^6.19.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
