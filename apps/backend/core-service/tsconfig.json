{
  "extends": "@pawhaven/tsconfig/node",
  "compilerOptions": {
    "outDir": "dist",
    "baseUrl": ".",
    "skipLibCheck": true,
    "declaration": false,
    "declarationMap": false,
    "paths": {
      "@modules/*": ["./src/modules/*"],
      "@prismaClient": ["src/prisma/mongodb/client"]
    }
  },
  "include": ["src"],
  "exclude": ["src/prisma/mongodb/base-model.snippet.prisma"]
}
