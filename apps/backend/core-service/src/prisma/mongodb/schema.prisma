generator client {
  provider        = "prisma-client-js"
  output          = "../mongodb/client"
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
  previewFeatures = ["relationJoins"]
  moduleFormat    = "cjs"
}

datasource db {
  provider = "mongodb"
  url      = env("CORE_SERVICE_MONGODB")
}

enum MenuType {
  link
  component
}

model Menu {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  status   String @default("active")
  version  Int    @default(1)
  tenantId String @default("system")

  label String   @unique
  type  MenuType

  to         String?
  component  String?
  classNames String[]
  order      Int

  menuPermissions MenuPermission[]
}

model Route {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  status   String @default("active")
  version  Int    @default(1)
  tenantId String @default("system")

  parentId String? @db.ObjectId
  parent   Route?  @relation("RouteTree", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children Route[] @relation("RouteTree")

  path    String?
  element String  @unique
  handle  Json?

  order Int?

  routePermissions RoutePermission[]

  @@index([parentId])
}

model Role {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  status String @default("active")
  key    String @unique
  name   String

  rolePermissions RolePermission[]
}

model Permission {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  status String @default("active")
  code   String @unique
  name   String

  rolePermissions  RolePermission[]
  menuPermissions  MenuPermission[]
  routePermissions RoutePermission[]
}

model RolePermission {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  roleId       String     @db.ObjectId
  permissionId String     @db.ObjectId
  role         Role       @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model MenuPermission {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  menuId       String     @db.ObjectId
  permissionId String     @db.ObjectId
  menu         Menu       @relation(fields: [menuId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([menuId, permissionId])
  @@index([menuId])
  @@index([permissionId])
}

model RoutePermission {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  routeId      String     @db.ObjectId
  permissionId String     @db.ObjectId
  route        Route      @relation(fields: [routeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([routeId, permissionId])
  @@index([routeId])
  @@index([permissionId])
}
